# Polymarket CLOB API
HOST=https://clob.polymarket.com
PK=
PBK=

# API Credentials (generated automatically)
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# Optional Redis integration (omit to run without Redis)
# REDIS_URL=redis://:polystation@redis:6379/0
REDIS_PASSWORD=polystation

# Grafana admin password (for Docker monitoring stack)
GRAFANA_PASSWORD=changeme

# Dashboard API authentication (leave empty to disable for local dev)
# POLYSTATION_API_TOKEN=

# Set to "false" to disable Swagger/ReDoc in production
# POLYSTATION_DOCS=true
